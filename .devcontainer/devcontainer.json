{
  "name": "BCL1223 Database Fundamentals Demo",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "customizations": {
    "vscode": {
      "extensions": [
        "bierner.markdown-preview-github-styles",
        "yzhang.markdown-all-in-one",
        "ms-python.python"
      ]
    }
  },
  "forwardPorts": [1521, 8978],
  "portsAttributes": {
    "8978": {
      "label": "CloudBeaver GUI",
      "onAutoForward": "openBrowser",
      "requireLocalPort": false
    }
  },
  "postCreateCommand": "bash .devcontainer/setup-oracle.sh",
  "postStartCommand": "bash .devcontainer/start-containers.sh"
}
